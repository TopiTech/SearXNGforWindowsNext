# Python bytecode and cache files
__pycache__/
*.py[cod]
*$py.class

# Temporary and log files
.upstream-tmp/
changed_files.txt
*.log
/scratch/

# OS and IDE files
Thumbs.db
Desktop.ini
.vscode/

# Ignore embedded Python third-party packages, except whitelisted libraries
/python/Lib/site-packages/*
!/python/Lib/site-packages/searx/
!/python/Lib/site-packages/searx/**
!/python/Lib/site-packages/searxng_extra/
!/python/Lib/site-packages/searxng_extra/**
!/python/Lib/site-packages/valkey/
!/python/Lib/site-packages/valkey/**

# Keep pip and its files in repository, but keep bytecode ignored.
!/python/Lib/site-packages/pip/
!/python/Lib/site-packages/pip-*.dist-info/
!/python/Lib/site-packages/setuptools/
!/python/Lib/site-packages/setuptools-*.dist-info/
!/python/Lib/site-packages/wheel/
!/python/Lib/site-packages/wheel-*.dist-info/
!/python/Scripts/pip.exe
!/python/Scripts/pip3.exe
!/python/Scripts/pip3.11.exe

# Keep bytecode ignored even inside whitelisted packages
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Ignore embedded Python scripts
/python/Scripts/*
